        "jsCode": "// ============================================\n// PARSE & FORMAT EMAIL - CODE NODE\n// Sender: Ahmed Farhan | Farhan AI\n// ============================================\n\nconst response = $input.first().json;\nconst content  = response.choices[0].message.content.trim();\nconst leadData = $('Is Status Pending?').first().json;\n\n// ============================================\n// PARSE JSON FROM AI OUTPUT\n// ============================================\n\nlet parsed;\ntry {\n  parsed = JSON.parse(content);\n} catch(e) {\n  parsed = {\n    subject          : 'Quick question for ' + leadData.First_Name,\n    greeting         : 'Hi ' + leadData.First_Name + ',',\n    opening_line     : '',\n    pain_point       : '',\n    value_proposition: content,\n    call_to_action   : '',\n    regards          : 'Warm regards,\\n\\nAhmed Farhan\\nFarhan AI\\nPhone: 01886435661\\nAddress: Gulshan, Dhaka'\n  };\n}\n\n// ============================================\n// HARDCODED SENDER (ALWAYS FIXED)\n// ============================================\n\nconst regards = `Warm regards,\n\nAhmed Farhan\nFarhan AI\nPhone: 01886435661\nAddress: Gulshan, Dhaka`;\n\n// ============================================\n// BUILD PLAIN TEXT EMAIL\n// ============================================\n\nconst plainEmail = `\nSubject: ${parsed.subject}\n\n${parsed.greeting}\n\n${parsed.opening_line}\n\n${parsed.pain_point}\n\n${parsed.value_proposition}\n\n${parsed.call_to_action}\n\n${regards}\n`.trim();\n\n// ============================================\n// BUILD HTML EMAIL\n// ============================================\n\nconst htmlEmail = `\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n</head>\n<body style=\"\n  margin:0;\n  padding:0;\n  background:#f0f2f5;\n  font-family:Arial,sans-serif;\n\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"\n    style=\"backgr