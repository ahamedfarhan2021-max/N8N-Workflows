    </tr>\n\n          <!-- SUBJECT LINE BOX -->\n          <tr>\n            <td style=\"padding:20px 36px 0;\">\n              <div style=\"\n                background:#e8f0fe;\n                border-left:4px solid #1a73e8;\n                padding:12px 16px;\n                border-radius:0 8px 8px 0;\n              \">\n                <p style=\"\n                  margin:0 0 4px;\n                  font-size:11px;\n                  color:#888;\n                  text-transform:uppercase;\n                  letter-spacing:1px;\n                \">Subject</p>\n                <p style=\"\n                  margin:0;\n                  font-size:15px;\n                  font-weight:700;\n                  color:#1a1a1a;\n                \">${parsed.subject}</p>\n              </div>\n            </td>\n          </tr>\n\n          <!-- EMAIL BODY -->\n          <tr>\n            <td style=\"padding:24px 36px 10px;\">\n\n              <!-- GREETING -->\n              <p style=\"\n                margin:0 0 16px 0;\n                font-size:15px;\n                font-weight:600;\n                color:#1a1a1a;\n              \">${parsed.greeting}</p>\n\n              <!-- OPENING LINE -->\n              <p style=\"\n                margin:0 0 14px 0;\n                font-size:15px;\n                color:#333;\n                line-height:1.8;\n              \">${parsed.opening_line}</p>\n\n              <!-- PAIN POINT -->\n              <p style=\"\n                margin:0 0 14px 0;\n                font-size:15px;\n                color:#333;\n                line-height:1.8;\n              \">${parsed.pain_point}</p>\n\n              <!-- VALUE PROPOSITION -->\n              <div style=\"\n                border-left:4px solid #1a73e8;\n                background:#f0f7ff;\n                padding:14px 18px;\n                border-radius:0 8px 8px 0;\n                margin:18px 0;\n              \">\n                <p style=\"\n                  margin