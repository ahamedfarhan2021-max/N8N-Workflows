      "parameters": {
        "jsCode": "// ============================================\n// PARSE & FORMAT EMAIL - CODE NODE\n// Fixed: Handles raw string output from AI Agent\n// ============================================\n\n// ============================================\n// STEP 1: GET RAW OUTPUT STRING\n// ============================================\n\nconst rawOutput = items[0].json.output || \"\";\n\n// ============================================\n// STEP 2: CLEAN THE RAW STRING\n// ============================================\n\nconst cleaned = rawOutput\n  .replace(/\\\\n/g, ' ')        // Remove \\n escape\n  .replace(/\\n/g, ' ')         // Remove actual newlines\n  .replace(/\\\\\"/g, '\"')        // Fix escaped quotes\n  .trim();\n\n// ============================================\n// STEP 3: PARSE JSON FROM CLEANED STRING\n// ============================================\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  // If JSON parse fails try to extract manually\n  parsed = {\n    subject          : cleaned.match(/\"subject\"\\s*:\\s*\"([^\"]+)\"/)?.[1]           || '',\n    greeting         : cleaned.match(/\"greeting\"\\s*:\\s*\"([^\"]+)\"/)?.[1]          || '',\n    opening_line     : cleaned.match(/\"opening_line\"\\s*:\\s*\"([^\"]+)\"/)?.[1]      || '',\n    pain_point       : cleaned.match(/\"pain_point\"\\s*:\\s*\"([^\"]+)\"/)?.[1]        || '',\n    value_proposition: cleaned.match(/\"value_proposition\"\\s*:\\s*\"([^\"]+)\"/)?.[1] || '',\n    call_to_action   : cleaned.match(/\"call_to_action\"\\s*:\\s*\"([^\"]+)\"/)?.[1]    || '',\n    regards          : cleaned.match(/\"regards\"\\s*:\\s*\"([^\"]+)\"/)?.[1]           || ''\n  };\n}\n\n// ============================================\n// STEP 4: HARDCODED SENDER DETAILS\n// ============================================\n\nconst sender = {\n  name   : \"Ahmed Farhan\",\n  company: \"Farhan AI\",\n  phone  : \"01886435661\",\n  address: \"Gulshan, Dhaka\"\n};\n\n// =========================