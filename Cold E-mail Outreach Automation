      "parameters": {
        "jsCode": "// ============================================\n// PARSE & FORMAT FOLLOW-UP EMAIL - CODE NODE\n// Sender: Ahmed Farhan | Farhan AI\n// ============================================\n\n// ============================================\n// STEP 1: GET RAW OUTPUT FROM AI AGENT\n// ============================================\n\nconst rawOutput = $input.first().json.output || \"\";\n\n// ============================================\n// STEP 2: CLEAN THE RAW STRING\n// ============================================\n\nconst cleaned = rawOutput\n  .replace(/\\\\n/g, ' ')\n  .replace(/\\n/g, ' ')\n  .replace(/\\\\\"/g, '\"')\n  .trim();\n\n// ============================================\n// STEP 3: PARSE JSON FROM CLEANED STRING\n// ============================================\n\nconst leadData = $('Is Status Pending?').first().json;\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = {\n    subject          : 'Re: Following up — ' + leadData.Company,\n    greeting         : 'Hi ' + leadData.First_Name + ',',\n    opening_line     : cleaned.match(/\"opening_line\"\\s*:\\s*\"([^\"]+)\"/)?.[1]      || '',\n    pain_point       : cleaned.match(/\"pain_point\"\\s*:\\s*\"([^\"]+)\"/)?.[1]        || '',\n    value_proposition: cleaned.match(/\"value_proposition\"\\s*:\\s*\"([^\"]+)\"/)?.[1] || cleaned,\n    call_to_action   : cleaned.match(/\"call_to_action\"\\s*:\\s*\"([^\"]+)\"/)?.[1]    || '',\n    regards          : 'Warm regards,\\n\\nAhmed Farhan\\nFarhan AI\\nPhone: 01886435661\\nAddress: Gulshan, Dhaka'\n  };\n}\n\n// ============================================\n// STEP 4: HARDCODED SENDER DETAILS\n// ============================================\n\nconst sender = {\n  name   : \"Ahmed Farhan\",\n  company: \"Farhan AI\",\n  phone  : \"01886435661\",\n  address: \"Gulshan, Dhaka\"\n};\n\nconst regards = `Warm regards,\\n\\nAhmed Farhan\\nFarhan AI\\nPhone: 01886435661\\nAddress: Gulshan, Dhaka`;\n\n// ============================================\n// STEP 5: BUILD PLAIN TEXT EMAIL\n// ============================================\n\nconst plainEmail = `\nSubject: ${parsed.subject}\n\n${parsed.greeting}\n\n${parsed.opening_line}\n\n${parsed.pain_point}\n\n${parsed.value_proposition}\n\n${parsed.call_to_action}\n\n${regards}\n`.trim();\n\n// ============================================\n// STEP 6: BUILD HTML EMAIL\n// ============================================\n\nconst htmlEmail = `\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n</head>\n<body style=\"\n  margin:0;\n  padding:0;\n  background:#f0f2f5;\n  font-family:Arial,sans-serif;\n\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"\n    style=\"background:#f0f2f5;padding:30px 15px;\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"580\" cellpadding=\"0\" cellspacing=\"0\"\n          style=\"\n            background:#ffffff;\n            border-radius:12px;\n            overflow:hidden;\n            box-shadow:0 4px 20px rgba(0,0,0,0.08);\n          \">\n\n          <!-- TOP BAR -->\n          <tr>\n            <td style=\"\n              background:linear-gradient(90deg,#1a73e8,#0d47a1);\n              height:5px;\n            \"></td>\n          </tr>\n\n          <!-- BRAND HEADER -->\n          <tr>\n            <td style=\"\n              padding:24px 36px 16px;\n              border-bottom:1px solid #f0f0f0;\n            \">\n              <p style=\"\n                margin:0;\n                font-size:20px;\n                font-weight:700;\n                color:#1a73e8;\n              \">Farhan AI</p>\n              <p style=\"\n                margin:4px 0 0;\n                font-size:12px;\n                color:#aaa;\n              \">AI Automation for Modern Businesses</p>\n            </td>\n          </tr>\n\n          <!-- FOLLOW-UP BADGE -->\n          <tr>\n            <td style=\"padding:16px 36px 0;\">\n              <span style=\"\n                display:inline-block;\n                background:#fff3e0;\n                color:#e65100;\n                font-size:11px;\n                font-weight:700;\n                padding:4px 12px;\n                border-radius:20px;\n                text-transform:uppercase;\n                letter-spacing:1px;\n              \">Follow-up</span>\n            </td>\n          </tr>\n\n          <!-- SUBJECT LINE BOX -->\n          <tr>\n            <td style=\"padding:12px 36px 0;\">\n              <div style=\"\n                background:#e8f0fe;\n                border-left:4px solid #1a73e8;\n                padding:12px 16px;\n                border-radius:0 8px 8px 0;\n              \">\n                <p style=\"\n                  margin:0;\n                  font-size:11px;\n                  color:#888;\n                  text-transform:uppercase;\n                  letter-spacing:1px;\n                  margin-bottom:4px;\n                \">Subject</p>\n                <p style=\"\n                  margin:0;\n                  font-size:15px;\n                  font-weight:700;\n                  color:#1a1a1a;\n                \">${parsed.subject}</p>\n              </div>\n            </td>\n          </tr>\n\n          <!-- EMAIL BODY -->\n          <tr>\n            <td style=\"padding:24px 36px 10px;\">\n\n              <!-- GREETING -->\n              <p style=\"\n                margin:0 0 16px 0;\n                font-size:15px;\n                font-weight:600;\n                color:#1a1a1a;\n              \">${parsed.greeting}</p>\n\n              <!-- OPENING LINE -->\n              <p style=\"\n                margin:0 0 14px 0;\n                font-size:15px;\n                color:#333;\n                line-height:1.8;\n              \">${parsed.opening_line}</p>\n\n              <!-- PAIN POINT -->\n              <p style=\"\n                margin:0 0 14px 0;\n                font-size:15px;\n                color:#333;\n                line-height:1.8;\n              \">${parsed.pain_point}</p>\n\n              <!-- VALUE PROPOSITION -->\n              <div style=\"\n                border-left:4px solid #1a73e8;\n                background:#f0f7ff;\n                padding:14px 18px;\n                border-radius:0 8px 8px 0;\n                margin:18px 0;\n              \">\n                <p style=\"\n                  margin:0;\n                  font-size:15px;\n                  color:#1a1a1a;\n                  line-height:1.8;\n                \">${parsed.value_proposition}</p>\n              </div>\n\n              <!-- CALL TO ACTION -->\n              <p style=\"\n                margin:0 0 20px 0;\n                font-size:15px;\n                color:#333;\n                line-height:1.8;\n              \">${parsed.call_to_action}</p>\n\n            </td>\n          </tr>\n\n          <!-- REGARDS SECTION -->\n          <tr>\n            <td style=\"\n              padding:0 36px 28px;\n              border-top:1px solid #f0f0f0;\n            \">\n              <p style=\"\n                margin:16px 0 14px;\n                font-size:15px;\n                color:#333;\n              \">Warm regards,</p>\n\n              <table cellpadding=\"0\" cellspacing=\"0\">\n                <tr>\n                  <td style=\"\n                    width:4px;\n                    background:linear-gradient(180deg,#1a73e8,#0d47a1);\n                    border-radius:4px;\n                  \"></td>\n                  <td style=\"padding-left:14px;\">\n                    <p style=\"\n                      margin:0 0 3px;\n                      font-size:15px;\n                      font-weight:700;\n                      color:#1a1a1a;\n                    \">${sender.name}</p>\n                    <p style=\"\n                      margin:0 0 3px;\n                      font-size:13px;\n                      color:#1a73e8;\n                      font-weight:600;\n                    \">${sender.company}</p>\n                    <p style=\"\n                      margin:0 0 2px;\n                      font-size:13px;\n                      color:#777;\n                    \">📞 ${sender.phone}</p>\n                    <p style=\"\n                      margin:0;\n                      font-size:13px;\n                      color:#777;\n                    \">📍 ${sender.address}</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- FOOTER -->\n          <tr>\n            <td style=\"\n              background:#f8f9fa;\n              padding:14px 36px;\n              border-top:1px solid #eee;\n              text-align:center;\n            \">\n              <p style=\"\n                margin:0;\n                font-size:11px;\n                color:#bbb;\n                line-height:1.6;\n              \">\n                This email was sent by Farhan AI Automation System.\n                Reply with Unsubscribe to opt out.\n              </p>\n            </td>\n          </tr>\n\n          <!-- BOTTOM BAR -->\n          <tr>\n            <td style=\"\n              background:linear-gradient(90deg,#1a73e8,#0d47a1);\n              height:4px;\n            \"></td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>\n`.trim();\n\n// ============================================\n// STEP 7: RETURN FINAL OUTPUT\n// ============================================\n\nreturn [{\n  json: {\n    ...leadData,\n    followup_subject : parsed.subject,\n    followup_body    : htmlEmail,\n    followup_plain   : plainEmail,\n    greeting         : parsed.greeting,\n    opening_line     : parsed.opening_line,\n    pain_point       : parsed.pain_point,\n    value_prop       : parsed.value_proposition,\n    cta              : parsed.call_to_action,\n    regards          : regards,\n    generated_at     : new Date().toISOString()\n  }\n}];"
      },
