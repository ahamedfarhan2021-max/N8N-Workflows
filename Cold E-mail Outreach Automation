\n          <tr>\n            <td style=\"padding:24px 36px 10px;\">\n\n              <!-- GREETING -->\n              <p style=\"\n                margin:0 0 16px 0;\n                font-size:15px;\n                font-weight:600;\n                color:#1a1a1a;\n              \">${parsed.greeting}</p>\n\n              <!-- OPENING LINE -->\n              <p style=\"\n                margin:0 0 14px 0;\n                font-size:15px;\n                color:#333;\n                line-height:1.8;\n              \">${parsed.opening_line}</p>\n\n              <!-- PAIN POINT -->\n              <p style=\"\n                margin:0 0 14px 0;\n                font-size:15px;\n                color:#333;\n                line-height:1.8;\n              \">${parsed.pain_point}</p>\n\n              <!-- VALUE PROPOSITION -->\n              <div style=\"\n                border-left:4px solid #1a73e8;\n                background:#f0f7ff;\n                padding:14px 18px;\n                border-radius:0 8px 8px 0;\n                margin:18px 0;\n              \">\n                <p style=\"\n                  margin:0;\n                  font-size:15px;\n                  color:#1a1a1a;\n                  line-height:1.8;\n                \">${parsed.value_proposition}</p>\n              </div>\n\n              <!-- CALL TO ACTION -->\n              <p style=\"\n                margin:0 0 20px 0;\n                font-size:15px;\n                color:#333;\n                line-height:1.8;\n              \">${parsed.call_to_action}</p>\n\n            </td>\n          </tr>\n\n          <!-- REGARDS SECTION -->\n          <tr>\n            <td style=\"\n              padding:0 36px 28px;\n              border-top:1px solid #f0f0f0;\n              margin-top:10px;\n            \">\n              <p style=\"\n                margin:16px 0 14px;\n                font-size:15px;\n                color:#333;\n              \">Warm regards,</p>\n\n              <table cellpadding=\"0\" cellspacing=\"0\">\n                <tr>\n                  <!-- LEFT COLOR BAR -->\n                  <td style=\"\n                    width:4px;\n                    background:linear-gradient(180deg,#1a73e8,#0d47a1);\n                    border-radius:4px;\n                  \"></td>\n\n                  <!-- SENDER DETAILS -->\n                  <td style=\"padding-left:14px;\">\n                    <p style=\"\n                      margin:0 0 3px;\n                      font-size:15px;\n                      font-weight:700;\n                      color:#1a1a1a;\n                    \">Ahmed Farhan</p>\n                    <p style=\"\n                      margin:0 0 3px;\n                      font-size:13px;\n                      color:#1a73e8;\n                      font-weight:600;\n                    \">Farhan AI</p>\n                    <p style=\"\n                      margin:0 0 2px;\n                      font-size:13px;\n                      color:#777;\n                    \">📞 01886435661</p>\n                    <p style=\"\n                      margin:0;\n                      font-size:13px;\n                      color:#777;\n                    \">📍 Gulshan, Dhaka</p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- FOOTER -->\n          <tr>\n            <td style=\"\n              background:#f8f9fa;\n              padding:14px 36px;\n              border-top:1px solid #eee;\n              text-align:center;\n            \">\n              <p style=\"\n                margin:0;\n                font-size:11px;\n                color:#bbb;\n                line-height:1.6;\n              \">\n                This email was sent by Farhan AI Automation System.\n                Reply with Unsubscribe to opt out.\n              </p>\n            </td>\n          </tr>\n\n          <!-- BOTTOM BAR -->\n          <tr>\n            <td style=\"\n              background:linear-gradient(90deg,#1a73e8,#0d47a1);\n              height:4px;\n            \"></td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>\n`.trim();\n\n// ============================================\n// RETURN FINAL OUTPUT\n// ============================================\n\nreturn [{\n  json: {\n    ...leadData,\n    email_subject : parsed.subject,\n    email_plain   : plainEmail,\n    email_html    : htmlEmail,\n    greeting      : parsed.greeting,\n    opening_line  : parsed.opening_line,\n    pain_point    : parsed.pain_point,\n    value_prop    : parsed.value_proposition,\n    cta           : parsed.call_to_action,\n    regards       : regards,\n    generated_at  : new Date().toISOString()\n  }\n}];"
