        "jsCode": "// ─────────────────────────────────────────────\n// STEP: Parse Classification Response\n// ─────────────────────────────────────────────\nconst item = $input.first().json;\nlet classificationResult;\n\ntry {\n  const rawResponse = item.message?.content || item.choices?.[0]?.message?.content || '{}';\n  classificationResult = typeof rawResponse === 'string' ? JSON.parse(rawResponse) : rawResponse;\n} catch (e) {\n  classificationResult = {\n    document_type: 'invoice',\n    confidence: 'low',\n    reasoning: 'Fallback: could not parse classification response'\n  };\n}\n\nconst validTypes = ['invoice', 'receipt', 'purchase_order'];\nif (!validTypes.includes(classificationResult.document_type)) {\n  classificationResult.document_type = 'invoice';\n  classificationResult.confidence = 'low';\n}\n\nreturn [{\n  json: {\n    ...item,\n    detected_document_type: classificationResult.document_type,\n    classification_confidence: classificationResult.confidence,\n    classification_reasoning: classificationResult.reasoning\n  }\n}];"
