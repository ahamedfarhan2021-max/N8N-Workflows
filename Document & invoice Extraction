      "parameters": {
        "jsCode": "const item = $input.first();\n\n// The trigger is already watching a specific folder.\n// We hardcode the type based on which workflow this is.\n// If you duplicate this workflow for Receipts, change this to 'receipt'.\n// If you duplicate for Purchase Orders, change this to 'purchase_order'.\n\nconst HARDCODED_DOC_TYPE = 'invoice'; // ← change this per workflow copy\n\nreturn [{\n  json: {\n    ...item.json,\n    document_type: HARDCODED_DOC_TYPE,\n    document_type_override: HARDCODED_DOC_TYPE,\n    folder_name: 'Invoices'\n  },\n  binary: item.binary\n}];"
