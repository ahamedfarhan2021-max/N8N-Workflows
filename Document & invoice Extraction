      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────\n// STEP: Build Document-Specific Extraction Prompt\n// ─────────────────────────────────────────────\nconst item = $input.first().json;\nconst docType = item.detected_document_type;\n\nconst commonInstructions = `\nRules:\n- Extract ONLY data explicitly present in the document. Do not infer or guess.\n- If a field is not present, use null.\n- All monetary values must be numeric (no currency symbols). 2 decimal places.\n- Dates must be ISO 8601 format: YYYY-MM-DD.\n- Line items must be an array even if there is only one item.\n- Return ONLY valid JSON. No markdown, no explanation, no preamble.\n`;\n\nlet extractionPrompt;\n\nif (docType === 'invoice') {\n  extractionPrompt = `You are an expert invoice data extraction AI. Extract all structured data from this invoice.\n\nReturn a JSON object with EXACTLY this schema:\n{\n  \"document_type\": \"invoice\",\n  \"invoice_number\": string | null,\n  \"invoice_date\": \"YYYY-MM-DD\" | null,\n  \"due_date\": \"YYYY-MM-DD\" | null,\n  \"payment_terms\": string | null,\n  \"currency\": string | null,\n  \"vendor\": {\n    \"name\": string | null,\n    \"address\": string | null,\n    \"email\": string | null,\n    \"phone\": string | null,\n    \"tax_id\": string | null,\n    \"bank_account\": string | null\n  },\n  \"bill_to\": {\n    \"name\": string | null,\n    \"address\": string | null,\n    \"email\": string | null,\n    \"contact\": string | null\n  },\n  \"ship_to\": {\n    \"name\": string | null,\n    \"address\": string | null\n  },\n  \"line_items\": [\n    {\n      \"line_number\": number | null,\n      \"description\": string,\n      \"quantity\": number | null,\n      \"unit\": string | null,\n      \"unit_price\": number | null,\n      \"discount_percent\": number | null,\n      \"discount_amount\": number | null,\n      \"tax_rate_percent\": number | null,\n      \"line_total\": number | null\n    }\n  ],\n  \"subtotal\": number | null,\n  \"discount_total\": number | null,\n  \"tax_total\": number | null,\n  \"shipping_cost\": number | null,\n  \"total_amount_due\": number | null,\n  \"amount_paid\": number | null,\n  \"balance_due\": number | null,\n  \"notes\": string | null,\n  \"po_reference\": string | null,\n  \"project_code\": string | null\n}\n\n${commonInstructions}`;\n\n} else if (docType === 'receipt') {\n  extractionPrompt = `You are an expert receipt data extraction AI. Extract all structured data from this receipt.\n\nReturn a JSON object with EXACTLY this schema:\n{\n  \"document_type\": \"receipt\",\n  \"receipt_number\": string | null,\n  \"transaction_date\": \"YYYY-MM-DD\" | null,\n  \"transaction_time\": string | null,\n  \"merchant\": {\n    \"name\": string | null,\n    \"address\": string | null,\n    \"phone\": string | null,\n    \"website\": string | null,\n    \"tax_id\": string | null,\n    \"terminal_id\": string | null,\n    \"cashier\": string | null\n  },\n  \"currency\": string | null,\n  \"line_items\": [\n    {\n      \"description\": string,\n      \"sku\": string | null,\n      \"quantity\": number | null,\n      \"unit_price\": number | null,\n      \"line_total\": number | null\n    }\n  ],\n  \"subtotal\": number | null,\n  \"tax_total\": number | null,\n  \"tip\": number | null,\n  \"discount_total\": number | null,\n  \"total_paid\": number | null,\n  \"payment_method\": string | null,\n  \"card_last_four\": string | null,\n  \"change_given\": number | null,\n  \"loyalty_points_earned\": number | null,\n  \"notes\": string | null\n}\n\n${commonInstructions}`;\n\n} else if (docType === 'purchase_order') {\n  extractionPrompt = `You are an expert purchase order data extraction AI. Extract all structured data from this purchase order.\n\nReturn a JSON object with EXACTLY this schema:\n{\n  \"document_type\": \"purchase_order\",\n  \"po_number\": string | null,\n  \"po_date\": \"YYYY-MM-DD\" | null,\n  \"delivery_date_requested\": \"YYYY-MM-DD\" | null,\n  \"status\": string | null,\n  \"currency\": string | null,\n  \"buyer\": {\n    \"company\": string | null,\n    \"department\": string | null,\n    \"contact_name\": string | null,\n    \"email\": string | null,\n    \"phone\": string | null,\n    \"address\": string | null\n  },\n  \"supplier\": {\n    \"name\": string | null,\n    \"contact_name\": string | null,\n    \"email\": string | null,\n    \"phone\": string | null,\n    \"address\": string | null\n  },\n  \"ship_to\": {\n    \"location\": string | null,\n    \"address\": string | null,\n    \"attention\": string | null\n  },\n  \"line_items\": [\n    {\n      \"line_number\": number | null,\n      \"item_code\": string | null,\n      \"description\": string,\n      \"quantity_ordered\": number | null,\n      \"unit\": string | null,\n      \"unit_price\": number | null,\n      \"tax_rate_percent\": number | null,\n      \"line_total\": number | null\n    }\n  ],\n  \"subtotal\": number | null,\n  \"tax_total\": number | null,\n  \"shipping_cost\": number | null,\n  \"total_amount\": number | null,\n  \"payment_terms\": string | null,\n  \"shipping_method\": string | null,\n  \"notes\": string | null,\n  \"approved_by\": string | null,\n  \"approval_date\": \"YYYY-MM-DD\" | null\n}\n\n${commonInstructions}`;\n\n} else {\n  throw new Error(`Unknown document type: ${docType}. Cannot build extraction prompt.`);\n}\n\nreturn [{\n  json: {\n    ...item,\n    extraction_prompt: extractionPrompt\n  }\n}];"
