      "parameters": {
        "jsCode": "const item = $input.first();\nconst meta = item.json;\nconst binaryData = item.binary;\n\n// ✅ FIX: Don't rely on file_key. Just grab whatever binary key exists.\nconst fileKey = meta.file_key || Object.keys(binaryData)[0];\nconst file = binaryData[fileKey];\n\nif (!file) {\n  throw new Error(`Binary file not found. Available keys: ${Object.keys(binaryData).join(', ')}`);\n}\n\nconst base64Content = file.data;\nconst mimeType = file.mimeType || meta.mime_type;\n\nconst mimeToType = {\n  'application/pdf': 'application/pdf',\n  'image/png': 'image/png',\n  'image/jpeg': 'image/jpeg',\n  'image/tiff': 'image/tiff',\n  'image/webp': 'image/webp'\n};\n\nconst openaiMediaType = mimeToType[mimeType] || 'image/jpeg';\nconst isPdf = mimeType === 'application/pdf';\n\nreturn [{\n  json: {\n    ...meta,\n    base64_content: base64Content,\n    openai_media_type: openaiMediaType,\n    is_pdf: isPdf\n  }\n}];"
      },
