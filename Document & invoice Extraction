      "name": "📁 Detect Doc Type From Folder",
      "notes": "FIXED: Uses folder ID (not folder name) to detect document type. Google Drive Trigger returns folder IDs, never folder names. Folder ID map is hardcoded here. Filename prefix is a secondary fallback."
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nconst binaryData = item.binary;\n\nif (!binaryData || Object.keys(binaryData).length === 0) {\n  throw new Error('No binary data found after download.');\n}\n\nconst fileKey = Object.keys(binaryData)[0];\nconst file = binaryData[fileKey];\n\nconst allowedMimeTypes = [\n  'application/pdf',\n  'image/png',\n  'image/jpeg',\n  'image/tiff',\n  'image/webp'\n];\n\nif (!allowedMimeTypes.includes(file.mimeType)) {\n  throw new Error(`Unsupported file type: ${file.mimeType}`);\n}\n\nconst maxSizeBytes = 20 * 1024 * 1024;\nif (file.fileSize && file.fileSize > maxSizeBytes) {\n  throw new Error(`File too large: ${(file.fileSize / 1024 / 1024).toFixed(1)}MB`);\n}\n\nconst submissionId = `DOC-${Date.now()}-${Math.random().toString(36).substr(2, 6).toUpperCase()}`;\n\n// ✅ KEY FIX: Read document_type_override directly from item.json\n// because the previous node (Detect Doc Type From Folder) already set it\nconst docTypeOverride = item.json.document_type_override || null;\n\nreturn [{\n  json: {\n    submission_id: submissionId,\n    file_key: fileKey,\n    mime_type: file.mimeType,\n    file_name: item.json.originalFilename || item.json.name || 'unknown_file',\n    file_size_bytes: file.fileSize || null,\n    drive_file_id: item.json.id || null,\n    drive_web_view_link: item.json.webViewLink || null,\n    document_type_override: docTypeOverride,  // ✅ carried forward correctly\n    folder_name: item.json.folder_name || null,\n    source_label: 'google_drive',\n    received_at: new Date().toISOString()\n  },\n  binary: binaryData\n}];"
      },
