        "jsCode": "// ─────────────────────────────────────────────\n// STEP: Parse & Validate Extracted Data\n// ─────────────────────────────────────────────\nconst item = $input.first().json;\nlet extractedData;\n\ntry {\n  const rawContent = item.message?.content || item.choices?.[0]?.message?.content || '{}';\n  extractedData = typeof rawContent === 'string' ? JSON.parse(rawContent) : rawContent;\n} catch (e) {\n  throw new Error(`Failed to parse GPT-4o extraction response: ${e.message}`);\n}\n\nconst qualityFlags = [];\nconst docType = item.detected_document_type;\n\nif (docType === 'invoice') {\n  if (!extractedData.invoice_number) qualityFlags.push('missing_invoice_number');\n  if (!extractedData.total_amount_due) qualityFlags.push('missing_total_amount');\n  if (!extractedData.vendor?.name) qualityFlags.push('missing_vendor_name');\n  if (!extractedData.invoice_date) qualityFlags.push('missing_invoice_date');\n} else if (docType === 'receipt') {\n  if (!extractedData.total_paid) qualityFlags.push('missing_total_paid');\n  if (!extractedData.merchant?.name) qualityFlags.push('missing_merchant_name');\n  if (!extractedData.transaction_date) qualityFlags.push('missing_transaction_date');\n} else if (docType === 'purchase_order') {\n  if (!extractedData.po_number) qualityFlags.push('missing_po_number');\n  if (!extractedData.total_amount) qualityFlags.push('missing_total_amount');\n  if (!extractedData.supplier?.name) qualityFlags.push('missing_supplier_name');\n}\n\nconst lineItemCount = extractedData.line_items ? extractedData.line_items.length : 0;\nconst lineItemsSummary = extractedData.line_items\n  ? extractedData.line_items.map(li => li.description || '').join('; ')\n  : '';\n\nconst sheetsRecord = {\n  submission_id: item.submission_id,\n  processed_at: new Date().toISOString(),\n  source_label: item.source_label,\n  file_name: item.file_name,\n  drive_file_id: item.drive_file_id,\n  drive_web_view_link: item.drive_web_view_link,\n  document_type: docType,\n  classification_confidence: item.classification_confidence,\n  quality_flags: qualityFlags.join(', ') || 'none',\n  extraction_quality: qualityFlags.length === 0 ? 'COMPLETE' : qualityFlags.length <= 2 ? 'PARTIAL' : 'POOR',\n  line_item_count: lineItemCount,\n  invoice_number: extractedData.invoice_number || null,\n  invoice_date: extractedData.invoice_date || null,\n  due_date: extractedData.due_date || null,\n  payment_terms: extractedData.payment_terms || null,\n  currency: extractedData.currency || null,\n  vendor_name: extractedData.vendor?.name || extractedData.merchant?.name || extractedData.supplier?.name || null,\n  vendor_address: extractedData.vendor?.address || extractedData.merchant?.address || extractedData.supplier?.address || null,\n  vendor_email: extractedData.vendor?.email || extractedData.merchant?.email || extractedData.supplier?.email || null,\n  vendor_phone: extractedData.vendor?.phone || extractedData.merchant?.phone || extractedData.supplier?.phone || null,\n  vendor_tax_id: extractedData.vendor?.tax_id || extractedData.merchant?.tax_id || null,\n  bill_to_name: extractedData.bill_to?.name || extractedData.buyer?.company || null,\n  bill_to_address: extractedData.bill_to?.address || extractedData.buyer?.address || null,\n  po_number: extractedData.po_number || extractedData.po_reference || null,\n  po_date: extractedData.po_date || null,\n  delivery_date_requested: extractedData.delivery_date_requested || null,\n  buyer_company: extractedData.buyer?.company || null,\n  approved_by: extractedData.approved_by || null,\n  approval_date: extractedData.approval_date || null,\n  shipping_method: extractedData.shipping_method || null,\n  receipt_number: extractedData.receipt_number || null,\n  transaction_date: extractedData.transaction_date || extractedData.invoice_date || extractedData.po_date || null,\n  transaction_time: extractedData.transaction_time || null,\n  payment_method: extractedData.payment_method || null,\n  card_last_four: extractedData.card_last_four || null,\n  cashier: extractedData.merchant?.cashier || null,\n  subtotal: extractedData.subtotal || null,\n  discount_total: extractedData.discount_total || null,\n  tax_total: extractedData.tax_total || null,\n  shipping_cost: extractedData.shipping_cost || null,\n  tip: extractedData.tip || null,\n  total_amount: extractedData.total_amount_due || extractedData.total_paid || extractedData.total_amount || null,\n  amount_paid: extractedData.amount_paid || extractedData.total_paid || null,\n  balance_due: extractedData.balance_due || null,\n  line_items_summary: lineItemsSummary,\n  line_items_json: JSON.stringify(extractedData.line_items || []),\n  notes: extractedData.notes || null,\n  project_code: extractedData.project_code || null,\n  raw_extraction_json: JSON.stringify(extractedData)\n};\n\nreturn [{\n  json: {\n    ...item,\n    extracted_data: extractedData,\n    sheets_record: sheetsRecord,\n    quality_flags: qualityFlags,\n    extraction_quality: sheetsRecord.extraction_quality\n  }\n}];"
