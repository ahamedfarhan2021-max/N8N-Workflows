      "parameters": {
        "jsCode": "const item = $input.first().json;\n\n// ✅ FIX: Explicit null/undefined check with fallback\nconst override = item.document_type_override;\nconst validTypes = ['invoice', 'receipt', 'purchase_order'];\n\nif (override && validTypes.includes(override)) {\n  // Document type is already known — skip GPT classification entirely\n  return [{\n    json: {\n      ...item,\n      detected_document_type: override,\n      classification_skipped: true,\n      classification_confidence: 'folder_detected'\n    }\n  }];\n}\n\n// Document type is unknown — build classification prompt for GPT-4o\nconst classificationPrompt = `You are a document classification expert. Analyze this document image and determine its type.\n\nRespond ONLY with a valid JSON object in this exact format:\n{\n  \"document_type\": \"invoice\" | \"receipt\" | \"purchase_order\",\n  \"confidence\": \"high\" | \"medium\" | \"low\",\n  \"reasoning\": \"Brief explanation of key indicators used\"\n}\n\nClassification Rules:\n- \"invoice\": Formal billing document from vendor/supplier to buyer. Has invoice number, payment terms, due date, billing/shipping address, line items with unit prices, subtotal, tax, total amount due.\n- \"receipt\": Proof of completed payment/transaction. From retail/restaurant/service. Has transaction date/time, items purchased, payment method used, total paid.\n- \"purchase_order\": Buyer-issued document authorizing a purchase from supplier. Has PO number, ship-to address, requested delivery date, approved line items, buyer authorization.\n\nIf uncertain, return the closest match with confidence: \"low\".`;\n\nreturn [{\n  json: {\n    ...item,\n    classification_prompt: classificationPrompt,\n    classification_skipped: false\n  }\n}];"
      },
