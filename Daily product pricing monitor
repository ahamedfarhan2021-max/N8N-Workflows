        "jsCode": "const item = $input.first().json;\n\n// Build a rich search query for Google Shopping\nconst parts = [\n  item.brand || '',\n  item.productName || '',\n  item.sku ? `(${item.sku})` : ''\n].filter(Boolean);\n\nconst searchQuery = parts.join(' ').trim();\n\nreturn [{\n  json: {\n    ...item,\n    searchQuery,\n    encodedQuery: encodeURIComponent(searchQuery)\n  }\n}];"
