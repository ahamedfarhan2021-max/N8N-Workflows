    {
      "parameters": {
        "jsCode": "const prev = $('Prepare Search Query').first().json;\nconst apiResponse = $input.first().json;\nconst shoppingResults = apiResponse.shopping_results || [];\n\nlet competitorPrices = [];\nlet lowestPrice = null;\nlet averagePrice = null;\nlet gapPercent = 0;\nlet severity = 'ok';\nlet suggestedPrice = null;\n\nif (shoppingResults.length > 0) {\n  competitorPrices = shoppingResults\n    .filter(r => r.price)\n    .map(r => ({\n      store: r.source || 'Unknown',\n      price: parseFloat(String(r.price).replace(/[^0-9.]/g, '')) || 0,\n      title: r.title || '',\n      link: r.link || ''\n    }))\n    .filter(r => r.price > 0);\n\n  if (competitorPrices.length > 0) {\n    const prices = competitorPrices.map(p => p.price);\n    lowestPrice = Math.min(...prices);\n    averagePrice = parseFloat((prices.reduce((a,b) => a+b,0) / prices.length).toFixed(2));\n\n    // Gap: positive = you are MORE expensive than competitor\n    gapPercent = parseFloat(((prev.yourPrice - lowestPrice) / lowestPrice * 100).toFixed(2));\n\n    if (gapPercent >= 20 || gapPercent <= -20) severity = 'critical';\n    else if (gapPercent >= 10 || gapPercent <= -10) severity = 'warning';\n    else severity = 'ok';\n\n    // Suggested price = 3% below lowest competitor (competitive but profitable)\n    suggestedPrice = parseFloat((lowestPrice * 0.97).toFixed(2));\n  }\n}\n\nreturn [{\n  json: {\n    productName:           prev.productName,\n    sku:                   prev.sku,\n    category:              prev.category,\n    brand:                 prev.brand,\n    yourPrice:             prev.yourPrice,\n    lowestCompetitorPrice: lowestPrice,\n    averageCompetitorPrice:averagePrice,\n    gapPercent,\n    severity,\n    suggestedPrice,\n    topCompetitors:        competitorPrices.slice(0, 5),\n    totalResultsFound:     competitorPrices.length,\n    analyzedAt:            new Date().toISOString()\n  }\n}];"
      },
