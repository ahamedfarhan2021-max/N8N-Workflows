      "parameters": {
        "jsCode": "// Retrieve all accumulated pricing results\nconst staticData = $getWorkflowStaticData('global');\nconst results = staticData.pricingResults || [];\n\nconst critical = results.filter(r => r.severity === 'critical');\nconst warnings  = results.filter(r => r.severity === 'warning');\nconst ok        = results.filter(r => r.severity === 'ok');\nconst today     = new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' });\n\n// ── HTML Email ────────────────────────────────────────────────────\nconst rowColor = s => s === 'critical' ? '#fff0f0' : s === 'warning' ? '#fffbf0' : '#f0fff4';\nconst badge    = s => s === 'critical'\n  ? '<span style=\"background:#dc3545;color:#fff;padding:2px 8px;border-radius:10px;font-size:12px\">CRITICAL</span>'\n  : s === 'warning'\n  ? '<span style=\"background:#fd7e14;color:#fff;padding:2px 8px;border-radius:10px;font-size:12px\">WARNING</span>'\n  : '<span style=\"background:#28a745;color:#fff;padding:2px 8px;border-radius:10px;font-size:12px\">OK</span>';\n\nconst tableRows = results.map(r => `\n  <tr style=\"background:${rowColor(r.severity)}\">\n    <td style=\"padding:8px 12px;border:1px solid #dee2e6\">${r.productName}</td>\n    <td style=\"padding:8px 12px;border:1px solid #dee2e6\">${r.sku || '—'}</td>\n    <td style=\"padding:8px 12px;border:1px solid #dee2e6;text-align:right\">$${r.yourPrice.toFixed(2)}</td>\n    <td style=\"padding:8px 12px;border:1px solid #dee2e6;text-align:right\">${r.lowestCompetitorPrice != null ? '$'+r.lowestCompetitorPrice.toFixed(2) : 'N/A'}</td>\n    <td style=\"padding:8px 12px;border:1px solid #dee2e6;text-align:right\">${r.gapPercent}%</td>\n    <td style=\"padding:8px 12px;border:1px solid #dee2e6;text-align:right\">${r.suggestedPrice != null ? '$'+r.suggestedPrice.toFixed(2) : 'N/A'}</td>\n    <td style=\"padding:8px 12px;border:1px solid #dee2e6;text-align:center\">${badge(r.severity)}</td>\n  </tr>`).join('');\n\nconst htmlReport = `<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\">\n<style>body{font-family:Arial,sans-serif;color:#333;max-width:900px;margin:0 auto;padding:20px}\nh1{color:#1a1a2e}th{background:#343a40;color:#fff;padding:10px 12px;text-align:left}\ntable{width:100%;border-collapse:collapse;margin-top:16px}</style>\n</head><body>\n<h1>📊 Daily Pricing Report — ${today}</h1>\n<p style=\"font-size:16px\">\n  <strong>Total Analyzed:</strong> ${results.length} &nbsp;|\n  <strong style=\"color:#dc3545\"> 🚨 Critical: ${critical.length}</strong> &nbsp;|\n  <strong style=\"color:#fd7e14\"> ⚠️ Warning: ${warnings.length}</strong> &nbsp;|\n  <strong style=\"color:#28a745\"> ✅ OK: ${ok.length}</strong>\n</p>\n<table>\n  <thead><tr>\n    <th>Product</th><th>SKU</th><th>Your Price</th>\n    <th>Lowest Competitor</th><th>Gap %</th><th>Suggested Price</th><th>Status</th>\n  </tr></thead>\n  <tbody>${tableRows}</tbody>\n</table>\n<p style=\"color:#888;font-size:12px;margin-top:24px\">Generated automatically by n8n Pricing Monitor</p>\n</body></html>`;\n\n// ── Slack Summary ─────────────────────────────────────────────────\nconst criticalLines = critical.map(r =>\n  `• *${r.productName}* — Yours $${r.yourPrice} vs $${r.lowestCompetitorPrice} (${r.gapPercent}%)`\n).join('\\n');\n\nconst warningLines = warnings.map(r =>\n  `• *${r.productName}* — Yours $${r.yourPrice} vs $${r.lowestCompetitorPrice} (${r.gapPercent}%)`\n).join('\\n');\n\nconst slackMessage = [\n  `📊 *Daily Pricing Report — ${today}*`,\n  `✅ Products Analyzed: *${results.length}*  |  🚨 Critical: *${critical.length}*  |  ⚠️ Warning: *${warnings.length}*  |  ✅ OK: *${ok.length}*`,\n  critical.length > 0 ? `\\n🚨 *Critical Alerts:*\\n${criticalLines}` : '',\n  warnings.length  > 0 ? `\\n⚠️ *Warnings:*\\n${warningLines}` : ''\n].filter(Boolean).join('\\n');\n\nreturn [{ json: { htmlReport, slackMessage, summary: { total: results.length, critical: critical.length, warnings: warnings.length, ok: ok.length }, reportDate: new Date().toISOString() } }];"
      },
