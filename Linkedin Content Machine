        "jsCode": "const now = new Date();\nconst cutoffTime = now.getTime() - (72 * 60 * 60 * 1000); // 72 hours ago\n\n// ─── 1. REDDIT (Apify) ───────────────────────────────────────────\nconst apifyRaw = $('Reddit').all();\nconst redditTopics = [];\n\nfor (const item of apifyRaw) {\n  const post = item.json;\n  const title = post.title || post.name || '';\n  const score = post.score || post.ups || 0;\n  const url = post.url || post.permalink || '';\n  \n  let postDate = null;\n  if (post.createdAt) postDate = new Date(post.createdAt);\n  else if (post.created_utc) postDate = new Date(post.created_utc * 1000);\n  else if (post.created) postDate = new Date(post.created * 1000);\n\n  if (!title) continue;\n  if (postDate && postDate.getTime() < cutoffTime) continue; // too old\n\n  redditTopics.push({\n    source: 'Reddit',\n    title,\n    score,\n    url,\n    publishedAt: postDate ? postDate.toISOString() : null,\n    relevanceScore: 0\n  });\n}\n\n// ─── 2. RSS FEEDS (TechCrunch, The Verge, Wired) ─────────────────\nconst rssSources = ['TechCrunch', 'The Verge', 'Wired'];\nconst rssTopics = [];\n\nfor (const sourceName of rssSources) {\n  try {\n    const items = $('TechCrunch' === sourceName ? 'TechCrunch' : sourceName === 'The Verge' ? 'The Verge' : 'Wired').all();\n    for (const item of items) {\n      const feed = item.json;\n      const entries = feed.items || feed.entries || (Array.isArray(feed) ? feed : []);\n      \n      for (const entry of entries.slice(0, 5)) {\n        const title = entry.title || '';\n        const url = entry.link || entry.url || '';\n        const pubDate = entry.pubDate || entry.published || entry.isoDate || null;\n        \n        let articleDate = null;\n        if (pubDate) articleDate = new Date(pubDate);\n\n        if (!title) continue;\n        if (articleDate && articleDate.getTime() < cutoffTime) continue; // too old\n\n        rssTopics.push({\n          source: sourceName,\n          title,\n          score: 50, // baseline score for news articles\n          url,\n          publishedAt: articleDate ? articleDate.toISOString() : null,\n          relevanceScore: 0\n        });\n      }\n    }\n  } catch(e) {\n    // source unavailable, skip\n  }\n}\n\n// ─── 3. GOOGLE TRENDS (SerpAPI) ──────────────────────────────────\nconst trendsRaw = $('Google_trends search').first().json;\nconst trendTopics = [];\n\nconst timelineData = trendsRaw?.interest_over_time?.timeline_data || [];\nconst latestPoint = timelineData[timelineData.length - 1];\n\nif (latestPoint?.values) {\n  for (const v of latestPoint.values) {\n    trendTopics.push({\n      source: 'GoogleTrends',\n      title: v.query,\n      score: parseInt(v.value) || 0,\n      url: '',\n      publishedAt: new Date().toISOString(),\n      relevanceScore: 0\n    });\n  }\n}\n\n// ─── 4. MERGE ALL SOURCES ─────────────────────────────────────────\nconst allTopics = [...redditTopics, ...rssTopics, ...trendTopics];\n\n// ─── 5. REMOVE DUPLICATES ─────────────────────────────────────────\n// Normalize title for comparison: lowercase, remove punctuation\nconst normalize = (str) => str.toLowerCase().replace(/[^a-z0-9\\s]/g, '').replace(/\\s+/g, ' ').trim();\n\nconst seen = new Set();\nconst deduplicated = [];\n\nfor (const topic of allTopics) {\n  const normalized = normalize(topic.title);\n  \n  // Check for exact or near-duplicate (first 60 chars match)\n  const fingerprint = normalized.substring(0, 60);\n  \n  if (!seen.has(fingerprint)) {\n    seen.add(fingerprint);\n    deduplicated.push(topic);\n  }\n}\n\n// ─── 6. RELEVANCE SCORING ─────────────────────────────────────────\n// Keywords most relevant to AI/tech LinkedIn audience\nconst highRelevanceKeywords = [\n  'ai', 'artificial intelligence', 'machine learning', 'llm', 'gpt',\n  'automation', 'chatgpt', 'openai', 'deep learning', 'neural',\n  'robot', 'tech', 'startup', 'founder', 'saas', 'productivity',\n  'future of work', 'claude', 'gemini', 'agent', 'model'\n];\n\nconst mediumRelevanceKeywords = [\n  'software', 'data', 'cloud', 'cybersecurity', 'blockchain',\n  'venture', 'funding', 'apple', 'google', 'microsoft', 'meta',\n  'innovation', 'digital', 'platform', 'developer', 'code'\n];\n\nfor (const topic of deduplicated) {\n  const titleLower = topic.title.toLowerCase();\n  let relevance = 0;\n\n  for (const kw of highRelevanceKeywords) {\n    if (titleLower.includes(kw)) relevance += 10;\n  }\n  for (const kw of mediumRelevanceKeywords) {\n    if (titleLower.includes(kw)) relevance += 5;\n  }\n\n  // Recency boost: published within last 24 hours gets +20\n  if (topic.publishedAt) {\n    const age = now.getTime() - new Date(topic.publishedAt).getTime();\n    const hoursOld = age / (1000 * 60 * 60);\n    if (hoursOld <= 24) relevance += 20;\n    else if (hoursOld <= 48) relevance += 10;\n  }\n\n  // Source credibility boost\n  if (topic.source === 'GoogleTrends') relevance += 8;\n  if (['TechCrunch', 'The Verge', 'Wired'].includes(topic.source)) relevance += 6;\n\n  // Engagement boost from Reddit score\n  if (topic.score > 1000) relevance += 15;\n  else if (topic.score > 500) relevance += 10;\n  else if (topic.score > 100) relevance += 5;\n\n  topic.relevanceScore = relevance;\n}\n\n// ─── 7. FINAL SORT: Most relevant first ───────────────────────────\nconst sorted = deduplicated.sort((a, b) => b.relevanceScore - a.relevanceScore);\n\n// ─── 8. PICK TOP TOPIC & BUILD OUTPUT ────────────────────────────\nconst topTopic = sorted[0] || {\n  title: 'The Future of AI and Automation in the Workplace',\n  source: 'Fallback',\n  relevanceScore: 0\n};\n\nconst stats = {\n  totalBeforeDedup: allTopics.length,\n  totalAfterDedup: deduplicated.length,\n  duplicatesRemoved: allTopics.length - deduplicated.length,\n  sourceBreakdown: {\n    reddit: redditTopics.length,\n    rss: rssTopics.length,\n    googleTrends: trendTopics.length\n  }\n};\n\nreturn [{\n  json: {\n    topTopic,\n    allTopics: sorted.slice(0, 10),\n    stats,\n    generatedAt: now.toISOString()\n  }\n}];"
      },
