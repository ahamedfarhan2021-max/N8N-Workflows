      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════════\n// QUALITY GATE CHECK — Safe Version\n// ═══════════════════════════════════════════════════════════\n\n// ─── SAFE DATA FETCHING ───────────────────────────────────\nlet postContent = '';\nlet topTopic = {};\n\n// Safely get post content\ntry {\n  const linkedInNode = $('Generate LinkedIn Post').first();\n  \n  // Try different response structures\n  if (linkedInNode.json?.message?.content) {\n    postContent = linkedInNode.json.message.content;\n  } else if (linkedInNode.json?.choices?.[0]?.message?.content) {\n    postContent = linkedInNode.json.choices[0].message.content;\n  } else if (linkedInNode.json?.text) {\n    postContent = linkedInNode.json.text;\n  } else if (linkedInNode.json?.content) {\n    postContent = linkedInNode.json.content;\n  } else {\n    postContent = JSON.stringify(linkedInNode.json);\n  }\n} catch(e) {\n  // Try getting from current input instead\n  try {\n    const inputData = $input.first();\n    postContent = inputData.json?.message?.content \n               || inputData.json?.text \n               || inputData.json?.content \n               || '';\n  } catch(e2) {\n    postContent = '';\n  }\n}\n\n// Safely get topic\ntry {\n  topTopic = $('Aggregate & Rank Topics').first().json?.topTopic || {};\n} catch(e) {\n  try {\n    topTopic = $input.first().json?.topTopic || {};\n  } catch(e2) {\n    topTopic = { title: 'Unknown Topic', source: 'Unknown' };\n  }\n}\n\n// ─── EMPTY CONTENT GUARD ─────────────────────────────────\nif (!postContent || postContent.trim().length === 0) {\n  return [{\n    json: {\n      approved: false,\n      postContent: '',\n      topTopic,\n      qualityScore: 0,\n      totalChecks: 10,\n      passedChecks: 0,\n      scorePercent: '0%',\n      failedChecks: [{ \n        check: 'Content exists', \n        value: 'Empty', \n        fix: 'Generate LinkedIn Post node returned no content' \n      }],\n      warnings: [],\n      verdict: 'REJECTED — NO CONTENT',\n      confidence: 'POOR',\n      fixInstructions: 'No content was generated. Check the Generate LinkedIn Post node.',\n      stats: {\n        wordCount: 0,\n        characterCount: 0,\n        paragraphCount: 0,\n        hashtagCount: 0,\n        hashtags: [],\n        buzzwordsFound: []\n      },\n      checkResults: {},\n      generatedAt: new Date().toISOString()\n    }\n  }];\n}\n\nconst post = postContent.trim();\n\n// ═══════════════════════════════════════════════════════════\n// HELPER FUNCTIONS\n// ═══════════════════════════════════════════════════════════\n\nconst countWords = (text) => {\n  return text\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .split(' ')\n    .filter(w => w.length > 0).length;\n};\n\nconst getParagraphs = (text) => {\n  return text\n    .split(/\\n\\s*\\n/)\n    .map(p => p.trim())\n    .filter(p => p.length > 0);\n};\n\nconst getLongestParagraphLines = (text) => {\n  const paragraphs = getParagraphs(text);\n  let max = 0;\n  for (const para of paragraphs) {\n    const lines = para\n      .split('\\n')\n      .filter(l => l.trim().length > 0).length;\n    if (lines > max) max = lines;\n  }\n  return max;\n};\n\nconst extractHashtags = (text) => {\n  return text.match(/#[\\w]+/g) || [];\n};\n\nconst hashtagsOnlyAtBottom = (text) => {\n  const lines = text.split('\\n');\n  let firstHashtagLine = -1;\n\n  for (let i = 0; i < lines.length; i++) {\n    if (/#[\\w]+/.test(lines[i])) {\n      firstHashtagLine = i;\n      break;\n    }\n  }\n\n  if (firstHashtagLine === -1) return false;\n\n  // Check no hashtags appear before the first hashtag line\n  // (they should all be grouped at bottom)\n  const bodyLines = lines.slice(0, firstHashtagLine);\n  const hashtagInBody = bodyLines.some(l => /#[\\w]+/.test(l));\n  \n  return !hashtagInBody;\n};\n\nconst WEAK_OPENERS = [\n  \"in today's fast-paced world\",\n  \"as we navigate\",\n  \"it's no secret that\",\n  \"exciting news\",\n  \"thrilled to announce\",\n  \"i am excited\",\n  \"i'm excited\",\n  \"i am pleased\",\n  \"i'm pleased\",\n  \"in the world of\",\n  \"in this day and age\",\n  \"now more than ever\",\n  \"in recent years\",\n  \"as we all know\",\n  \"needless to say\"\n];\n\nconst hasWeakOpener = (text) => {\n  const firstLine = text.split('\\n')[0].toLowerCase();\n  return WEAK_OPENERS.some(opener => firstLine.includes(opener));\n};\n\nconst BUZZWORDS = [\n  'game-changer', 'game changer', 'synergy', 'synergize',\n  'leverage', 'leveraging', 'disruptive', 'disrupting the',\n  'thought leader', 'thought leadership', 'best practices',\n  'move the needle', 'low-hanging fruit', 'circle back',\n  'deep dive', 'double down', 'at the end of the day',\n  'bleeding edge', 'cutting-edge solutions', 'revolutionary',\n  'paradigm shift', 'value proposition', 'going forward',\n  'take it to the next level', 'bandwidth', 'holistic approach'\n];\n\nconst findBuzzwords = (text) => {\n  const lower = text.toLowerCase();\n  return BUZZWORDS.filter(bw => lower.includes(bw));\n};\n\nconst endsWithQuestion = (text) => {\n  const lines = text\n    .split('\\n')\n    .map(l => l.trim())\n    .filter(l => l.length > 0);\n\n  // Filter out hashtag-only lines\n  const nonHashtagLines = lines.filter(l => {\n    const withoutHashtags = l.replace(/#[\\w]+/g, '').trim();\n    return withoutHashtags.length > 0;\n  });\n\n  if (nonHashtagLines.length === 0) return false;\n\n  const lastLine = nonHashtagLines[nonHashtagLines.length - 1];\n  return lastLine.endsWith('?');\n};\n\nconst WEAK_QUESTIONS = [\n  'what do you think?',\n  'thoughts?',\n  'agree or disagree?',\n  'do you agree?',\n  'let me know what you think',\n  'share your thoughts'\n];\n\nconst hasWeakQuestion = (text) => {\n  const lower = text.toLowerCase();\n  const lastLines = lower.split('\\n').slice(-5).join(' ');\n  return WEAK_QUESTIONS.some(q => lastLines.includes(q));\n};\n\nconst startsWithI = (text) => {\n  return /^I[\\s,']/.test(text.trim());\n};\n\nconst hasSuspiciousStats = (text) => {\n  return /\\b(100%|0%|\\d{4,}%)\\b/.test(text);\n};\n\nconst hasProperLineSpacing = (text) => {\n  return /\\n\\s*\\n/.test(text);\n};\n\n// ═══════════════════════════════════════════════════════════\n// CALCULATE ALL VALUES FIRST\n// ═══════════════════════════════════════════════════════════\n\nconst wordCount      = countWords(post);\nconst hashtags       = extractHashtags(post);\nconst paragraphs     = getParagraphs(post);\nconst buzzwordsFound = findBuzzwords(post);\nconst longestPara    = getLongestParagraphLines(post);\nconst firstWord      = post.trim().split(/\\s/)[0] || '';\nconst firstLine      = post.split('\\n')[0].trim().substring(0, 80);\nconst questionExists = endsWithQuestion(post);\nconst weakQuestion   = hasWeakQuestion(post);\n\n// ═══════════════════════════════════════════════════════════\n// RUN ALL 10 QUALITY CHECKS\n// ═══════════════════════════════════════════════════════════\n\nconst checks = {\n\n  wordCount: {\n    label  : 'Word count is between 150 and 300',\n    passed : wordCount >= 150 && wordCount <= 300,\n    value  : `${wordCount} words`,\n    fix    : wordCount < 150\n               ? `Too short — ${wordCount} words. Expand with more insight or examples`\n               : `Too long — ${wordCount} words. Cut filler, keep only sharpest ideas`\n  },\n\n  hookStrength: {\n    label  : 'First line is not a weak opener',\n    passed : !hasWeakOpener(post),\n    value  : `\"${firstLine}...\"`,\n    fix    : 'Rewrite the first line — avoid clichés, open with a bold claim or surprising fact'\n  },\n\n  noStartWithI: {\n    label  : 'Post does not start with the word \"I\"',\n    passed : !startsWithI(post),\n    value  : `First word: \"${firstWord}\"`,\n    fix    : 'Rewrite the opening — start with the topic, a number, or an action word'\n  },\n\n  hasHashtags: {\n    label  : 'Contains 3 to 5 hashtags',\n    passed : hashtags.length >= 3 && hashtags.length <= 5,\n    value  : `${hashtags.length} hashtags found: ${hashtags.join(', ')}`,\n    fix    : hashtags.length < 3\n               ? `Only ${hashtags.length} hashtag(s) — add ${3 - hashtags.length} more relevant ones`\n               : `Too many hashtags (${hashtags.length}) — remove ${hashtags.length - 5} to keep only top 5`\n  },\n\n  hashtagsAtBottom: {\n    label  : 'All hashtags are placed at the end only',\n    passed : hashtags.length === 0 ? false : hashtagsOnlyAtBottom(post),\n    value  : 'Hashtag placement scan complete',\n    fix    : 'Move all hashtags to the very last line — never embed them inside body text'\n  },\n\n  endsWithQuestion: {\n    label  : 'Post ends with a strong engaging question',\n    passed : questionExists && !weakQuestion,\n    value  : questionExists\n               ? (weakQuestion ? 'Weak question detected' : 'Strong question found')\n               : 'No question detected',\n    fix    : weakQuestion\n               ? 'Replace the generic question with something specific and debatable'\n               : 'Add a specific, thought-provoking question just before the hashtags'\n  },\n\n  lineSpacing: {\n    label  : 'Uses blank lines between paragraphs',\n    passed : hasProperLineSpacing(post),\n    value  : `${paragraphs.length} paragraph(s) detected`,\n    fix    : 'Add blank lines between every paragraph — LinkedIn collapses walls of text'\n  },\n\n  paragraphLength: {\n    label  : 'No paragraph is longer than 3 lines',\n    passed : longestPara <= 3,\n    value  : `Longest paragraph: ${longestPara} line(s)`,\n    fix    : 'Break up long paragraphs — aim for max 2 sentences per block'\n  },\n\n  noBuzzwords: {\n    label  : 'No hollow corporate buzzwords used',\n    passed : buzzwordsFound.length === 0,\n    value  : buzzwordsFound.length > 0\n               ? `Found: ${buzzwordsFound.join(', ')}`\n               : 'Clean — no buzzwords detected',\n    fix    : `Replace these words with plain language: ${buzzwordsFound.join(', ')}`\n  },\n\n  characterLength: {\n    label  : 'Post is at least 500 characters',\n    passed : post.length >= 500,\n    value  : `${post.length} characters`,\n    fix    : `Too short — only ${post.length} chars. LinkedIn favors richer, longer content`\n  }\n\n};\n\n// ═══════════════════════════════════════════════════════════\n// SCORING\n// ═══════════════════════════════════════════════════════════\n\nconst checkKeys    = Object.keys(checks);\nconst totalChecks  = checkKeys.length;\nconst passedChecks = checkKeys.filter(k => checks[k].passed).length;\nconst failedChecks = checkKeys\n  .filter(k => !checks[k].passed)\n  .map(k => ({\n    check : checks[k].label,\n    value : checks[k].value,\n    fix   : checks[k].fix\n  }));\n\nconst scorePercent = Math.round((passedChecks / totalChecks) * 100);\n\n// ─── APPROVAL LOGIC ───────────────────────────────────────\n// Must score 7/10 AND pass all 3 critical checks\nconst CRITICAL_CHECKS  = ['wordCount', 'hasHashtags', 'endsWithQuestion'];\nconst criticalPassed   = CRITICAL_CHECKS.every(k => checks[k].passed);\nconst approved         = passedChecks >= 7 && criticalPassed;\n\n// ─── CONFIDENCE ───────────────────────────────────────────\nlet confidence;\nif (scorePercent >= 90)      confidence = 'EXCELLENT';\nelse if (scorePercent >= 70) confidence = 'GOOD';\nelse if (scorePercent >= 50) confidence = 'NEEDS WORK';\nelse                         confidence = 'POOR';\n\n// ─── VERDICT ──────────────────────────────────────────────\nlet verdict;\nif (approved && scorePercent >= 90)    verdict = 'APPROVED — EXCELLENT';\nelse if (approved)                     verdict = 'APPROVED — GOOD';\nelse if (!criticalPassed)              verdict = 'REJECTED — CRITICAL CHECKS FAILED';\nelse                                   verdict = 'REJECTED — NEEDS IMPROVEMENT';\n\n// ─── WARNINGS ─────────────────────────────────────────────\nconst warnings = [];\n\nif (wordCount >= 150 && wordCount < 170) {\n  warnings.push('Word count close to minimum — consider adding more depth');\n}\nif (wordCount > 260 && wordCount <= 300) {\n  warnings.push('Word count near limit — consider trimming for punchiness');\n}\nif (hashtags.length === 3) {\n  warnings.push('Only 3 hashtags — adding 1-2 more could improve reach');\n}\nif (paragraphs.length < 3) {\n  warnings.push('Very few paragraphs — more structure improves readability');\n}\nif (hasSuspiciousStats(post)) {\n  warnings.push('Unusual statistics detected — verify all numbers are accurate');\n}\n\n// ─── FIX INSTRUCTIONS FOR REGENERATE NODE ─────────────────\nconst fixInstructions = !approved && failedChecks.length > 0\n  ? `Fix these ${failedChecks.length} issue(s):\\n` +\n    failedChecks\n      .map((f, i) => `${i + 1}. ${f.check}\\n   → ${f.fix}`)\n      .join('\\n')\n  : null;\n\n// ═══════════════════════════════════════════════════════════\n// FINAL OUTPUT\n// ═══════════════════════════════════════════════════════════\n\nreturn [{\n  json: {\n    approved,\n    verdict,\n    confidence,\n    qualityScore   : passedChecks,\n    totalChecks,\n    scorePercent   : `${scorePercent}%`,\n    postContent    : post,\n    topTopic,\n    checkResults   : checks,\n    failedChecks,\n    warnings,\n    stats: {\n      wordCount,\n      characterCount : post.length,\n      paragraphCount : paragraphs.length,\n      hashtagCount   : hashtags.length,\n      hashtags,\n      buzzwordsFound\n    },\n    fixInstructions,\n    generatedAt    : new Date().toISOString()\n  }\n}];"
      },
